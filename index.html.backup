<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Docker Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-orange: #FF9500;
            --dark-orange: #E67E00;
            --light-orange: #FFB84D;
            --black: #0A0A0A;
            --dark-gray: #1A1A1A;
            --medium-gray: #2A2A2A;
            --light-gray: #CCCCCC;
            --white: #FFFFFF;
            --off-white: #F5F5F5;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
            --glow: 0 0 20px rgba(255, 149, 0, 0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, var(--black) 0%, var(--dark-gray) 50%, var(--black) 100%);
            min-height: 100vh;
            padding: 1.5rem;
            color: var(--off-white);
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
        }

        h1 {
            color: var(--white);
            text-align: center;
            margin-bottom: 1.5rem;
            font-size: 2.5rem;
            text-shadow: 0 0 20px rgba(255, 149, 0, 0.5);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 900;
        }

        .category {
            margin-bottom: 1.5rem;
        }

        .category-title {
            color: var(--white);
            font-size: 1.3rem;
            margin-bottom: 0.75rem;
            padding-left: 0.75rem;
            border-left: 4px solid var(--primary-orange);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .services {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
        }

        .service-card {
            background: linear-gradient(135deg, var(--dark-gray) 0%, var(--medium-gray) 100%);
            border: 2px solid var(--medium-gray);
            border-radius: 0.75rem;
            padding: 1rem;
            box-shadow: var(--shadow);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary-orange), var(--dark-orange));
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .service-card:hover::before {
            transform: scaleX(1);
        }

        .service-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary-orange);
            box-shadow: var(--glow);
        }

        .service-link {
            text-decoration: none;
            color: inherit;
            display: block;
            margin-bottom: 0.75rem;
        }

        .service-header {
            display: flex;
            align-items: center;
            margin-bottom: 0.5rem;
        }

        .service-icon {
            font-size: 1.75rem;
            margin-right: 0.75rem;
            color: var(--primary-orange);
        }

        .service-name {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--white);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .service-description {
            color: var(--light-gray);
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
            line-height: 1.4;
        }

        .service-url {
            color: var(--primary-orange);
            font-size: 0.8rem;
            font-family: 'Monaco', 'Menlo', monospace;
            margin-bottom: 0.75rem;
            display: block;
        }

        .service-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.75rem;
        }

        .action-btn {
            flex: 1;
            padding: 0.5rem;
            border: none;
            border-radius: 0.4rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
        }

        .action-btn i {
            font-size: 0.85rem;
        }

        .restart-btn {
            background-color: transparent;
            color: var(--primary-orange);
            border: 1px solid var(--primary-orange);
        }

        .restart-btn:hover {
            background-color: var(--primary-orange);
            color: var(--black);
        }

        .recreate-btn {
            background-color: transparent;
            color: var(--light-orange);
            border: 1px solid var(--light-orange);
        }

        .recreate-btn:hover {
            background-color: var(--light-orange);
            color: var(--black);
        }

        .action-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .action-btn.loading {
            position: relative;
            color: transparent;
        }

        .action-btn.loading::after {
            content: '';
            position: absolute;
            width: 14px;
            height: 14px;
            border: 2px solid var(--primary-orange);
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--medium-gray);
            color: var(--white);
            padding: 1rem 1.5rem;
            border-radius: 0.5rem;
            border-left: 4px solid var(--primary-orange);
            box-shadow: var(--shadow);
            transform: translateX(400px);
            transition: transform 0.3s ease;
            z-index: 1000;
            max-width: 300px;
        }

        .toast.show {
            transform: translateX(0);
        }

        .toast.error {
            border-left-color: #f44336;
        }

        .toast.success {
            border-left-color: #4CAF50;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🐳 Docker Dashboard</h1>

        <div class="category">
            <h2 class="category-title">📖 Reading</h2>
            <div class="services">
                <a href="http://100.123.154.40:8007" class="service-card" target="_blank">
